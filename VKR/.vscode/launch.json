{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"type": "cppdbg",
			"request": "launch",
			"name": "Debug - Engine.AssetPipeline",
			"program": "${workspaceFolder}/build/Engine.AssetPipeline",
			"cwd": "${workspaceFolder}",
			"args": ["-Path.AssetsDir", "Assets/"],
			"preLaunchTask": "Build - Engine.AssetPipeline"
		},
		{
			"type": "cppdbg",
			"request": "launch",
			"name": "Debug - Engine.Runtime",
			"program": "${workspaceFolder}/build/Engine.Runtime",
			"cwd": "${workspaceFolder}",
			"args": ["-fps=144"],
			"preLaunchTask": "Build - Engine.Runtime"
		},
		{
			"type": "cppdbg",
			"request": "launch",
			"name": "Debug - Engine.Editor",
			"program": "${workspaceFolder}/build/Engine.Editor",
			"cwd": "${workspaceFolder}",
			"args": ["-fps=144"],
			"preLaunchTask": "Build - Engine.Editor"
		},
		{
			"type": "cppdbg",
			"request": "launch",
			"name": "Debug - Engine.Control",
			"program": "${workspaceFolder}/build/Engine.Control",
			"cwd": "${workspaceFolder}",
			"args": ["-Path.SourceDir", "src/Engine.Runtime/"],
			"preLaunchTask": "Build - Engine.Control"
		}
	]
}