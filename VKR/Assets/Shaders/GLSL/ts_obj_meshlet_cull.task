#version 460
#extension GL_ARB_separate_shader_objects : require
#extension GL_EXT_mesh_shader : require

#include "Common/pb_common.h"
#include "Common/vertex_common.h"
#include "Common/drawbatch_common.h"
#include "Common/culling_common.h"

#define MAX_DRAW_COUNT 8

//#define TASK_SEARCHER_SEARCH_COUNT 64
//#define TASK_SEARCHER_COUNT 256 / TASK_SEARCHER_SEARCH_COUNT
layout (local_size_x = DRAWBATCH_TASK_GROUP_SIZE, local_size_y = 1, local_size_z = 1) in;

DEFINE_DRAWBATCH_BINDINGS;

DEFINE_CULL_VIEW_CONSTANTS_UBO(cullConstants);                  
#define CULL_CONSTANTS PB_UBO(cullConstants, cullConstantsIndex)

layout(set = 0, binding = 2) readonly restrict buffer DrawRangesBuffer
{
    uvec2 ranges[MAX_DRAW_COUNT];
} drawRangesBuffer[];
#define DRAW_RANGES PB_STORAGE_BUFFER(drawRangesBuffer, drawRangeBufferIndex).ranges

layout(set = 0, binding = 2, std430) readonly restrict buffer MeshletBuffer
{
    MeshletData meshlets[];
} meshletBuffer[];

layout(set = 0, binding = 2, std430) readonly restrict buffer InstanceBuffer
{
    VS_INSTANCE instances[];
} instanceBuffer[];

layout(set = 0, binding = 2) readonly buffer MeshLibraryBuffer
{
    MeshLibraryEntry entries[];
} meshLibraryBuffer[];
#define MESH_LIBRARY_ENTRIES PB_STORAGE_BUFFER(meshLibraryBuffer, meshLibraryBufferIndex).entries

layout(set = 0, binding = 2, std430) readonly restrict buffer MeshletRangesBuffer
{
    uvec2 ranges[];
} meshletRangesBuffer[];
#define MESHLET_RANGES PB_STORAGE_BUFFER(meshletRangesBuffer, meshletRangesBufferIndex)

struct TASK_PAYLOAD
{
    uint packedVertOffsetCount[DRAWBATCH_TASK_GROUP_SIZE];
    uint packedPrimOffsetCount[DRAWBATCH_TASK_GROUP_SIZE];
    uint instanceIds[DRAWBATCH_TASK_GROUP_SIZE];
};

// One per set of mesh shader workgroups dispatched by a single task shader workgroup.
taskPayloadSharedEXT TASK_PAYLOAD payloadOut;

shared uint passingMeshletCount;

const float halfPi = 1.57079632679; // 90 degrees.

bool IsFrontFaceVisible(in vec3 meshletCenter, vec3 meanNormal, in float angularSpan)
{
    float sinConeAngle = sin(min(angularSpan, halfPi)); // Max 90 degrees.
    if(CULL_CONSTANTS.isOrthographic > 0)
    {
        vec3 camForward = CULL_CONSTANTS.mainFrustrumPlanes[0].xyz; // Orthographic projection can just use the camera's forward vector.
        return dot(meanNormal, camForward) < sinConeAngle;
    }

    vec3 centreDir = normalize(meshletCenter - CULL_CONSTANTS.cameraOrigin);

    return dot(meanNormal, centreDir) < sinConeAngle;
}

uint GetRangeEnd(in uint rangeIndex)
{
    return MESHLET_RANGES.ranges[rangeIndex][0];
}

uint GetRangeStart(in uint rangeIndex)
{
    return ((rangeIndex > 0) ? MESHLET_RANGES.ranges[rangeIndex - 1][0] : 0);
}

uint GetLOD(in uint rangeIndex)
{
    return MESHLET_RANGES.ranges[rangeIndex][1];
}

// ------------------------------------------ BACKUP METHOD ------------------------------------------
/*
uint FindInstanceId(uint meshletIdx)
{
    uint prevFooting = 0;
    uint footing = 0;
    uint prevJumpBack = DRAWBATCH_MAX_INSTANCES;
    for(uint i = 0; i < 8; ++i)
    {
        uint rangeEnd = GetRangeEnd(footing);
        uint rangeStart = GetRangeStart(footing);

        if(meshletIdx < rangeStart)
        {
            prevJumpBack /= 2;
            footing = prevFooting - prevJumpBack;
            prevFooting = footing;
