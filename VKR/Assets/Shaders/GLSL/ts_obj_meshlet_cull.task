        }
    }

    return footing;
}
*/
// ------------------------------------------ BACKUP METHOD ------------------------------------------


// This algorithm is a non-branching version of the algorithm above. The above algorithm is kept for readability.
// Recursively search for the range the meshlet index resides within. The index of this range is the instance index.
// Perform a binary tree-like search for the range:
uint FindInstanceId(uint meshletIdx)
{
    uint prevFooting = 0;
    uint footing = 0;
    uint prevJumpBack = DRAWBATCH_MAX_INSTANCES;
    for(uint i = 0; i < 8; ++i)
    {
        uint rangeEnd = GetRangeEnd(footing);
        uint rangeStart = GetRangeStart(footing);

        prevJumpBack /= 2;
        footing -= uint(meshletIdx < rangeStart) * prevJumpBack;
        footing += uint(meshletIdx >= rangeStart && meshletIdx >= rangeEnd) * prevJumpBack;
    }

    return footing;
}

void main()
{
    if(gl_LocalInvocationID.x == 0)
        passingMeshletCount = 0;

    barrier();
    memoryBarrierShared();

    uvec2 range = DRAW_RANGES[gl_DrawID];
    uint globalMeshletIndex = range[0] + gl_GlobalInvocationID.x;

    // ------------------------------------------ BACKUP METHOD ------------------------------------------
    // Search for the meshlet range this index resides within. The index of that range will be the object instance index.
    // uint searchIndex = gl_LocalInvocationID.y * TASK_SEARCHER_SEARCH_COUNT;
    // for(uint i = 0; i < TASK_SEARCHER_SEARCH_COUNT; ++i)
    // {
    //     uvec2 range = MESHLET_RANGES.ranges[searchIndex + i];
    //     if(globalMeshletIndex >= range[0] && globalMeshletIndex < range[1])
    //     {
    //         instanceId = searchIndex + i;
    //         instanceOffset = range[0];
    //     }
    // }
    // ------------------------------------------ BACKUP METHOD ------------------------------------------

    uint instanceId = ~uint(0);
    uint instanceOffset = ~uint(0);
    instanceId = FindInstanceId(globalMeshletIndex);
    instanceOffset = GetRangeStart(instanceId);

    VS_INSTANCE instanceData = PB_STORAGE_BUFFER(instanceBuffer, instanceBufferIndex).instances[instanceId];
    MeshLibraryEntry mesh = MESH_LIBRARY_ENTRIES[instanceData.meshID];

    uint lod = GetLOD(instanceId);
    uvec2 lodMeshletRange = uvec2
    (
        (lod > 0) ? mesh.lodMeshletEndOffsets[lod - 1] : 0,
        mesh.lodMeshletEndOffsets[lod]
    );
    uint lodMeshletCount = lodMeshletRange[1] - lodMeshletRange[0];

    uint meshletIdx = globalMeshletIndex - instanceOffset;
    MeshletData meshletData = PB_STORAGE_BUFFER_NU(meshletBuffer, mesh.meshletBufferIndex).meshlets[meshletIdx + lodMeshletRange[0]];

    vec3 meshletNormal;
    float meshletAngularSpan;
    {
        // Transform meshlet bounding sphere to match instance transform.
        TransformSphere(instanceData.model, meshletData.center, meshletData.radius);

        // Transform meshlet normal to match instance transform.
        vec4 normalUnpacked = vec4(unpackHalf2x16(meshletData.normalDataXYPacked), unpackHalf2x16(meshletData.normalDataZThetaPacked));
        meshletAngularSpan = normalUnpacked.w;
        normalUnpacked.w = 0.0;

        meshletNormal = normalize(instanceData.model * normalUnpacked).xyz;
    }

    // LOD mask.
    bool pass = meshletIdx < lodMeshletCount;

    // Mask out meshlets outside of the range.
    pass = pass && globalMeshletIndex < range[1];

    // Frustrum intersection test.
    pass = pass && IsInFrontOfPlane(CULL_CONSTANTS.mainFrustrumPlanes[0], meshletData.center, meshletData.radius)  // Near
	            && IsInFrontOfPlane(CULL_CONSTANTS.mainFrustrumPlanes[1], meshletData.center, meshletData.radius)  // Left
		        && IsInFrontOfPlane(CULL_CONSTANTS.mainFrustrumPlanes[2], meshletData.center, meshletData.radius)  // Right
	            && IsInFrontOfPlane(CULL_CONSTANTS.mainFrustrumPlanes[3], meshletData.center, meshletData.radius)  // Top
	            && IsInFrontOfPlane(CULL_CONSTANTS.mainFrustrumPlanes[4], meshletData.center, meshletData.radius)  // Bottom
                && IsInFrontOfPlane(CULL_CONSTANTS.mainFrustrumPlanes[5], meshletData.center, meshletData.radius); // Far

    // Front face visibility test.
    pass = pass && IsFrontFaceVisible(meshletData.center, meshletNormal, meshletAngularSpan);

    if (pass == true)
    {
        // Atomic increment the passing meshlet count for a invocation-unique index to write out passing meshlet's index to.
        uint outputIndex = atomicAdd(passingMeshletCount, 1);

        // Pack meshlet vertex/primitive offsets and counts for use in mesh shader.
        payloadOut.packedVertOffsetCount[outputIndex] = meshletData.vertOffsetCountPacked;
        payloadOut.packedPrimOffsetCount[outputIndex] = meshletData.primOffsetCountPacked;
        payloadOut.instanceIds[outputIndex] = instanceId;
    }

    // Amount of mesh shader workgroups to dispatch.
    EmitMeshTasksEXT(passingMeshletCount, 1, 1);
}