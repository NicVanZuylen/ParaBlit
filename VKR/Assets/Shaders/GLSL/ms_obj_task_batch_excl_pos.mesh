#version 460

#include "Common/pb_common.h"
#include "Common/vertex_common.h"
#include "Common/view_constants.h"
#include "Common/drawbatch_common.h"

#extension GL_ARB_separate_shader_objects : require
#extension GL_EXT_mesh_shader : require

#define TASK_GROUP_SIZE 32
#define MESHLET_PRIMITIVE_COUNT 32
#define MESHLET_VERTEX_COUNT MESHLET_PRIMITIVE_COUNT * 3

layout (local_size_x = MESHLET_PRIMITIVE_COUNT, local_size_y = 1, local_size_z = 1) in;
layout (triangles) out;
layout (max_vertices=MESHLET_VERTEX_COUNT, max_primitives=MESHLET_PRIMITIVE_COUNT) out;

layout(push_constant) uniform Bindings
{
    DEFINE_REQUIRED_UNIFORM_BINDINGS;
    uint indexBufferIndex;
    uint primitiveIndexBufferIndex;
    uint drawRangeBufferIndex;
    uint meshetDataBufferIndex;
    uint instanceBufferIndex;
} PB_BINDINGS_NAME;

DEFINE_VIEW_CONSTANTS(viewConstants);
#define VIEW_CONST PB_UBO(viewConstants, viewConstIndex)

#define INSTANCE_TEXTURE_COUNT 6
struct VS_INSTANCE
{
    mat4 model;
    uint textureIndices[INSTANCE_TEXTURE_COUNT];
    uint vertexIndex;
    uint samplerIndex;
};

layout(set = 0, binding = 2, std430) readonly restrict buffer IndexBuffer
{
    uint indices[];
} indexBuffer[];

layout(set = 0, binding = 2, std430) readonly restrict buffer PrimitiveBuffer
{
    uint primitivePackedIndices[];
} primitiveBuffer[];

layout(set = 0, binding = 2, std430) readonly restrict buffer VertexBuffer
{
    VS_IN vertices[];
} vertexBuffer[];

layout(set = 0, binding = 2, std430) readonly restrict buffer InstanceBuffer
{
    VS_INSTANCE instances[];
} instanceBuffer[];

struct TASK_PAYLOAD
{
    uint packedVertOffsetCount[TASK_GROUP_SIZE];
    uint packedPrimOffsetCount[TASK_GROUP_SIZE];
};
taskPayloadSharedEXT TASK_PAYLOAD payloadIn;

shared VS_INSTANCE instanceData;

void ProcessVertex(in VS_INSTANCE instanceData, uint vertexIndex, uint outVertexIndex)
{
    VS_IN vertexData = PB_STORAGE_BUFFER_NU(vertexBuffer, instanceData.vertexIndex).vertices[vertexIndex];

    vec4 position;
    vec2 texCoord;
    vec3 normal;
    vec3 tangent;
    UnpackVertexAttibutes(vertexData, position, texCoord, normal, tangent);

    gl_MeshVerticesEXT[outVertexIndex].gl_Position = VIEW_CONST.viewProj * instanceData.model * position;
}

uint GetVertexIndex(uint index)
{
    uint indicesPacked = PB_STORAGE_BUFFER(indexBuffer, indexBufferIndex).indices[index];
    return indicesPacked & 0xFFFFFF;
}

uint GetInstanceIndex(uint index)
{
    uint indicesPacked = PB_STORAGE_BUFFER(indexBuffer, indexBufferIndex).indices[index];
    return indicesPacked >> 24;
}

uvec3 GetPrimitiveIndices(uint index)
{
    uint primitiveIndices = PB_STORAGE_BUFFER(primitiveBuffer, primitiveIndexBufferIndex).primitivePackedIndices[index];
    return uvec3(primitiveIndices & 0x3FF, (primitiveIndices >> 10) & 0x3FF, (primitiveIndices >> 20) & 0x3FF);
}

void main()
{
    // Unpack vertex and primitive offsets and counts.
    uint packedVertOffsetCount = payloadIn.packedVertOffsetCount[gl_WorkGroupID.x];
    uint packedPrimOffsetCount = payloadIn.packedPrimOffsetCount[gl_WorkGroupID.x];
    uint vertexOffset = packedVertOffsetCount & 0xFFFFFF;
    uint vertexCount = packedVertOffsetCount >> 24;
    uint primitiveOffset = packedPrimOffsetCount & 0xFFFFFF;
    uint primitiveCount = packedPrimOffsetCount >> 24;

    SetMeshOutputsEXT(vertexCount, primitiveCount);

    uint baseVertexIndex = gl_LocalInvocationID.x * 3;
    if(baseVertexIndex == 0)
    {
       // Only obtain instance data for the first vertex. All vertices/primitives within the meshlet this work group is assigned to will belong to the same instance.
       instanceData = PB_STORAGE_BUFFER(instanceBuffer, instanceBufferIndex).instances[GetInstanceIndex(vertexOffset)];
    }

    barrier();

    // Shade 3 vertices per invocation.
    if(baseVertexIndex < vertexCount) // Vertex count will be a multiple of 3 in most cases, so only check base index.
    {
        uint firstVertexIndex = GetVertexIndex(vertexOffset + baseVertexIndex);
        ProcessVertex(instanceData, firstVertexIndex, baseVertexIndex);

        uint secondVertexIndex = GetVertexIndex(vertexOffset + baseVertexIndex + 1);
        ProcessVertex(instanceData, secondVertexIndex, baseVertexIndex + 1);

        uint thirdVertexIndex = GetVertexIndex(vertexOffset + baseVertexIndex + 2);
        ProcessVertex(instanceData, thirdVertexIndex, baseVertexIndex + 2);
    }

    // Output data for 1 primitive per invocation.
    uint primitiveIndex = gl_LocalInvocationID.x;
    if(primitiveIndex < primitiveCount)
    {
        gl_PrimitiveTriangleIndicesEXT[primitiveIndex] = GetPrimitiveIndices(primitiveOffset + primitiveIndex);
    }
}