#version 450

#include "Common/pb_common.h"
#include "Common/view_constants.h"
#include "Common/vertex_common.h"

#extension GL_ARB_separate_shader_objects : require
#extension GL_EXT_mesh_shader : require

#define TASK_GROUP_SIZE 32
#define MESHLET_PRIMITIVE_COUNT 32
#define MESHLET_VERTEX_COUNT MESHLET_PRIMITIVE_COUNT * 3

layout (local_size_x = MESHLET_PRIMITIVE_COUNT, local_size_y = 1, local_size_z = 1) in;
layout (triangles) out;
layout (max_vertices=MESHLET_VERTEX_COUNT, max_primitives=MESHLET_PRIMITIVE_COUNT) out;

layout(push_constant) uniform Bindings
{
    uint viewConstIndex;
    uint indexBufferIndex;
    uint instanceBufferIndex;
} PB_BINDINGS_NAME;

DEFINE_VIEW_CONSTANTS(viewConstants);
#define VIEW_CONST PB_UBO(viewConstants, viewConstIndex)

#define INSTANCE_TEXTURE_COUNT 6
struct VS_INSTANCE
{
    mat4 model;
    uint textureIndices[INSTANCE_TEXTURE_COUNT];
    uint vertexIndex;
    uint samplerIndex;
};

layout(set = 0, binding = 2, std430) readonly buffer IndexBuffer
{
    uint indices[];
} indexBuffer[];

layout(set = 0, binding = 2, std430) readonly buffer VertexBuffer
{
    VS_IN vertices[];
} vertexBuffer[];

layout(set = 0, binding = 2, std430) readonly buffer InstanceBuffer
{
    VS_INSTANCE instances[];
} instanceBuffer[];

//struct TASK_PAYLOAD
//{
//    uint passingMeshletIndices[TASK_GROUP_SIZE];
//};

// One per set of mesh shader workgroups dispatched by a single task shader workgroup.
//taskPayloadSharedEXT TASK_PAYLOAD payloadOut;

layout(location = 0) out VERTEX_OUT
{
    vec4 position;
    vec2 texCoord;

    mat3 tbnMatrix; // Normal is 3rd vector component.
} vertOutput[];

layout(location = 5) perprimitiveEXT out PRIMITIVE_OUT
{
    // Resource indices can be output at a per primitive rate.
    flat uint meshletIdx;
    flat uint meshletCount;
    flat uint samplerIdx;
    flat uint vertexIndex;
    flat uint textureIndices[INSTANCE_TEXTURE_COUNT];
} primOutput[];

void ProcessVertex(in VS_INSTANCE instanceData, uint outPrimitiveIndex, uint outVertexIndex)
{
    uint indexInputIndex = (gl_WorkGroupID.x * MESHLET_VERTEX_COUNT) + outVertexIndex;
    uint inputPackedIndex = PB_STORAGE_BUFFER(indexBuffer, indexBufferIndex).indices[indexInputIndex];
    uint inVertexIndex = uint(inputPackedIndex) & 0xFFFFFF; // Mask out final 8 bits for vertex index.

    VS_IN vertexData = vertexBuffer[nonuniformEXT(instanceData.vertexIndex)].vertices[inVertexIndex];

    vec4 position;
    vec2 texCoord;
    vec3 normal;
    vec3 tangent;
    UnpackVertexAttibutes(vertexData, position, texCoord, normal, tangent);

    mat3 modelCpy = mat3(instanceData.model);
    vec3 biTangent = -cross(normal, tangent);

    vertOutput[outVertexIndex].tbnMatrix = mat3
    (
        modelCpy * tangent,     // t
        modelCpy * biTangent,   // b
        modelCpy * normal       // n
    );

    gl_MeshVerticesEXT[outVertexIndex].gl_Position = VIEW_CONST.viewProj * instanceData.model * position;
    vertOutput[outVertexIndex].position = instanceData.model * position;
    vertOutput[outVertexIndex].position.w = 1.0;
    vertOutput[outVertexIndex].texCoord = texCoord;
}

void main()
{
    SetMeshOutputsEXT(MESHLET_VERTEX_COUNT, MESHLET_PRIMITIVE_COUNT);

    uint outPrimitiveIndex = gl_LocalInvocationID.x;
    uint outFirstVertexIndex = outPrimitiveIndex * 3;

    // Any given vertex in a primitive is expected to belong to the same common instance.
    uint firstPackedIndex = PB_STORAGE_BUFFER(indexBuffer, indexBufferIndex).indices[gl_WorkGroupID.x * MESHLET_VERTEX_COUNT];
    uint instanceIndex = uint(firstPackedIndex) >> 24; // Shift 24 bits right for instance index.
    VS_INSTANCE instanceData = PB_STORAGE_BUFFER(instanceBuffer, instanceBufferIndex).instances[instanceIndex];

    // Output resource bindings at a per-primitive rate for the reason above.
    primOutput[outPrimitiveIndex].samplerIdx = instanceData.samplerIndex;
    for(uint i = 0; i < INSTANCE_TEXTURE_COUNT; ++i)
        primOutput[outPrimitiveIndex].textureIndices[i] = instanceData.textureIndices[i];

    // Create vertices for a triangle.
    ProcessVertex(instanceData, outPrimitiveIndex, outFirstVertexIndex + 0);
    ProcessVertex(instanceData, outPrimitiveIndex, outFirstVertexIndex + 1);
    ProcessVertex(instanceData, outPrimitiveIndex, outFirstVertexIndex + 2);

    primOutput[outPrimitiveIndex].meshletIdx = gl_WorkGroupID.x;
    primOutput[outPrimitiveIndex].meshletCount = gl_NumWorkGroups.x;

    gl_PrimitiveTriangleIndicesEXT[outPrimitiveIndex] = uvec3(outFirstVertexIndex, outFirstVertexIndex + 1, outFirstVertexIndex + 2);
}